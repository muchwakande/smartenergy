# Copy to .env in the repo root and fill in real values.
# Both pi-aggregator/ and cloud/ read this file via
# `docker compose --env-file ../.env up -d` (see README for exact commands).

# --- Shared secret between NodeMCU devices and the Pi aggregator ---
PI_API_KEY=change-me-shared-secret

# --- Cloud InfluxDB (also used by the Pi aggregator's forwarder) ---
# CLOUD_INFLUX_URL should be the public HTTPS URL of your cloud server,
# e.g. https://energy.example.com (Caddy proxies /api/v2/write to InfluxDB).
CLOUD_INFLUX_URL=https://energy.example.com
CLOUD_INFLUX_ORG=smartenergy
CLOUD_INFLUX_BUCKET=energy
CLOUD_INFLUX_TOKEN=change-me-influx-admin-token

# --- InfluxDB container bootstrap (cloud only) ---
INFLUXDB_INIT_USERNAME=admin
INFLUXDB_INIT_PASSWORD=change-me-influxdb-password

# --- Grafana (cloud only) ---
GRAFANA_ADMIN_PASSWORD=change-me-grafana-password

# --- Caddy / TLS (cloud only) ---
# Domain must have a DNS A record pointing at the VPS for Caddy to obtain
# a Let's Encrypt certificate automatically. Without a real domain, Caddy
# will not be able to get a certificate - see README for local-testing
# alternatives.
CLOUD_DOMAIN=energy.example.com
